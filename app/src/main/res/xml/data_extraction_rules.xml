<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules to control what application data is backed up.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>

        <!-- Include the encrypted database and its security preferences -->
        <include domain="database" path="hometutorpro.db"/>
        <include domain="sharedpref" path="db_security_prefs"/>

        <!-- Include user settings from DataStore -->
        <include domain="file" path="datastore/"/>
    </cloud-backup>

    <device-transfer>
        <!-- Similar rules for device transfer to maintain security and consistency -->
        <include domain="database" path="hometutorpro.db"/>
        <include domain="sharedpref" path="db_security_prefs"/>
        <include domain="file" path="datastore/"/>
    </device-transfer>
</data-extraction-rules>
