<?xml version="1.0" encoding="utf-8"?>
<!--
   Backup rules to exclude sensitive data from Android backups for devices older than API 31.
   See https://developer.android.com/guide/topics/data/autobackup for details.
-->
<full-backup-content>
    <!-- Exclude the encrypted database and its security preferences since data is synced to Firestore -->
    <exclude domain="database" path="hometutorpro.db"/>
    <exclude domain="sharedpref" path="db_security_prefs"/>
    
    <!-- Include user settings from DataStore -->
    <include domain="file" path="datastore/"/>
</full-backup-content>
